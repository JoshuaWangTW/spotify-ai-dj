generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String?  @unique
  passwordHash        String?
  spotifyUserId       String?  @unique
  displayName         String?
  spotifyRefreshToken String?
  djPersonaId         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  musicProfile           MusicProfile?
  sessions               ListeningSession[]
  radioSessions          RadioSession[]
  djScriptCaches         DjScriptCache[]
  assistantConversations AssistantConversation[]
  musicMemories          MusicMemory[]
  feedback               TrackFeedback[]
}

model MusicProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  tasteSummary   String   @default("")
  avoidSummary   String   @default("")
  classicalLevel String   @default("beginner")
  jazzLevel      String   @default("beginner")
  situationRules Json?
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ListeningSession {
  id         String   @id @default(cuid())
  userId     String
  mode       String
  userPrompt String
  aiPlanJson Json
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model RadioSession {
  id                  String    @id @default(cuid())
  userId              String
  status              String    @default("active")
  mode                String
  userPrompt          String
  programmingContext  Json
  currentSegmentIndex Int       @default(0)
  startedAt           DateTime  @default(now())
  endedAt             DateTime?
  updatedAt           DateTime  @updatedAt

  user     User           @relation(fields: [userId], references: [id])
  segments RadioSegment[]
  events   RadioEvent[]

  @@index([userId, status])
}

model RadioSegment {
  id              String   @id @default(cuid())
  sessionId       String
  index           Int
  mode            String
  situation       String
  energy          Float
  djIntro         String
  planJson        Json
  trackQueries    String[]
  queuedTrackUris String[]
  createdAt       DateTime @default(now())

  session RadioSession @relation(fields: [sessionId], references: [id])
  events  RadioEvent[]

  @@unique([sessionId, index])
  @@index([sessionId])
}

model RadioEvent {
  id        String   @id @default(cuid())
  sessionId String
  segmentId String?
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  session RadioSession  @relation(fields: [sessionId], references: [id])
  segment RadioSegment? @relation(fields: [segmentId], references: [id])

  @@index([sessionId, createdAt])
  @@index([segmentId])
}

model DjScriptCache {
  id         String   @id @default(cuid())
  userId     String
  cacheKey   String   @unique
  script     String   @db.Text
  hitCount   Int      @default(0)
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, lastUsedAt])
}

model TtsAudioCache {
  id         String   @id @default(cuid())
  scriptHash String   @unique
  voiceId    String
  audioUrl   String
  duration   Int
  byteSize   Int
  hitCount   Int      @default(0)
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  @@index([lastUsedAt])
}

model TrackFeedback {
  id             String   @id @default(cuid())
  userId         String
  spotifyTrackId String
  feedbackType   String
  context        String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AssistantConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User               @relation(fields: [userId], references: [id])
  messages AssistantMessage[]

  @@index([userId, updatedAt])
}

model AssistantMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation AssistantConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
}

model MusicMemory {
  id         String    @id @default(cuid())
  userId     String
  type       String
  content    String
  confidence Float     @default(0.6)
  source     String    @default("assistant_chat")
  status     String    @default("active")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type, status])
}

model MusicNote {
  id                 String   @id @default(cuid())
  type               String
  title              String
  artistOrComposer   String
  style              String
  difficulty         String
  introShort         String
  listeningPoints    Json
  spotifySearchQuery String
  tags               String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}
