{
  "name": "spotify-ai-dj",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.6.0 <25",
    "pnpm": "10.32.1"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/test-env-core.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types prisma/seed.ts",
    "format": "prettier --write app components lib prisma scripts *.json *.js *.mjs *.ts",
    "format:check": "prettier --check app components lib prisma scripts *.json *.js *.mjs *.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "20.14.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "8.4.35",
    "dotenv": "^17.2.3",
    "prettier": "3.8.3",
    "prisma": "^6.19.0",
    "tailwindcss": "3.4.4",
    "typescript": "5.5.4"
  }
}
